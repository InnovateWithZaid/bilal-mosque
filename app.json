{
  "expo": {
    "name": "Bilal",
    "slug": "bilal-mosque-app-salah-timings-mosque-community",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bilal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6FBFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6FBFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bilalmosque.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bilal uses your photo library so admins can add mosque cover photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f735a09a-d06e-41e7-b164-1836a7c0ef04"
      }
    },
    "owner": "zaids-org"
  }
}
